{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "White",
  "slug": "white",
  "blockTypes": ["core/button"],
  "styles": {
    "color": {
      "background": "transparent",
      "text": "var(--wp--preset--color--white)"
    },
    "border": {
      "radius": "30px",
      "style": "solid",
      "width": "1px",
      "color": "var(--wp--preset--color--white)"
    },
    "css": "&:hover { background-color: var(--wp--preset--color--white); color: var(--wp--preset--color--black); }"
  }
}
