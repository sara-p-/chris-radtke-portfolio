{
  "$schema": "https://schemas.wp.org/wp/7.0/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        {
          "color": "#5b5b5b",
          "name": "Black",
          "slug": "black"
        },
        {
          "color": "#fffefa",
          "name": "White",
          "slug": "white"
        }
      ]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1180px"
    },
    "spacing": {
      "units": ["%", "px", "em", "rem", "vh", "vw"],
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "name": "XXS",
          "size": "1rem",
          "slug": "18"
        },
        {
          "name": "XS",
          "size": "clamp(1rem, calc(0.667rem + 1.25vw), 1.5rem)",
          "slug": "28"
        },
        {
          "name": "S",
          "size": "clamp(1.33rem, calc(0.55rem + 2.925vw), 2.5rem)",
          "slug": "45"
        },
        {
          "name": "M",
          "size": "clamp(1.44rem, calc(0.4rem + 3.9vw), 3rem)",
          "slug": "54"
        },
        {
          "name": "L",
          "size": "clamp(1.6rem, calc(-0.667rem + 8.5vw), 5rem)",
          "slug": "90"
        },
        {
          "name": "XL",
          "size": "clamp(1.89rem, calc(-1.737rem + 13.6vw), 7.33rem)",
          "slug": "132"
        },
        {
          "name": "XXL",
          "size": "clamp(2.6rem, calc(-3.8rem + 24vw), 12.2rem)",
          "slug": "220"
        },
        {
          "name": "XXXL",
          "size": "clamp(1.95rem, calc(-10.083rem + 45.125vw), 20rem)",
          "slug": "360"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
          "name": "System Font",
          "slug": "system-font"
        },
        {
          "fontFace": [
            {
              "fontFamily": "\"Albert Sans\"",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/albert-sans/albert-sans-400-normal.woff2"
              ]
            },
            {
              "fontFamily": "\"Albert Sans\"",
              "fontStyle": "normal",
              "fontWeight": "500",
              "src": [
                "file:./assets/fonts/albert-sans/albert-sans-500-normal.woff2"
              ]
            },
            {
              "fontFamily": "\"Albert Sans\"",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": [
                "file:./assets/fonts/albert-sans/albert-sans-700-normal.woff2"
              ]
            },
            {
              "fontFamily": "\"Albert Sans\"",
              "fontStyle": "normal",
              "fontWeight": "600",
              "src": [
                "file:./assets/fonts/albert-sans/albert-sans-600-normal.woff2"
              ]
            }
          ],
          "fontFamily": "\"Albert Sans\", sans-serif",
          "name": "Albert Sans",
          "slug": "albert-sans"
        },
        {
          "fontFace": [
            {
              "fontFamily": "\"Source Serif 4\"",
              "fontStyle": "italic",
              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/source-serif-4/source-serif-4-400-italic.woff2"
              ]
            }
          ],
          "fontFamily": "\"Source Serif 4\", serif",
          "name": "Source Serif 4",
          "slug": "source-serif-4"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--black)"
    },
    "elements": {
      "button": {
        "color": {
          "background": "transparent",
          "text": "var(--wp--preset--color--black)"
        },
        "border": {
          "color": "var(--wp--preset--color--black)",
          "radius": "30px",
          "style": "solid",
          "width": "1px"
        },
        "spacing": {
          "padding": {
            "bottom": "4px",
            "left": "4rem",
            "right": "4rem",
            "top": "4px"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--black)",
            "text": "var(--wp--preset--color--white)"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--albert-sans)",
          "textTransform": "uppercase",
          "fontWeight": "700",
          "letterSpacing": "5.6px"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--black)"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "clamp(4.72rem, calc(3.426rem + 4.861vw), 6.67rem)",
          "fontFamily": "var(--wp--preset--font-family--albert-sans)",
          "fontWeight": "600",
          "lineHeight": "0.18",
          "letterSpacing": "-4.8px"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "clamp(1.94rem, calc(1.389rem + 2.083vw), 2.78rem)",
          "fontFamily": "var(--wp--preset--font-family--source-serif-4)",
          "fontWeight": "400",
          "lineHeight": "1",
          "letterSpacing": "-2px",
          "fontStyle": "italic"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "clamp(1.78rem, calc(1.407rem + 1.389vw), 2.33rem)",
          "fontFamily": "var(--wp--preset--font-family--albert-sans)",
          "fontWeight": "700",
          "lineHeight": "0.51",
          "letterSpacing": "4.9px",
          "textTransform": "uppercase"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "clamp(1.78rem, calc(1.407rem + 1.389vw), 2.33rem)",
          "fontFamily": "var(--wp--preset--font-family--source-serif-4)",
          "fontWeight": "400",
          "lineHeight": "1",
          "letterSpacing": "-2px",
          "fontStyle": "italic"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "clamp(1.33rem, calc(0.889rem + 1.667vw), 2.00rem)",
          "fontFamily": "var(--wp--preset--font-family--source-serif-4)",
          "fontWeight": "400",
          "lineHeight": "1",
          "letterSpacing": "-2px",
          "fontStyle": "italic"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "clamp(0.78rem, calc(0.704rem + 0.278vw), 0.89rem)",
          "fontFamily": "var(--wp--preset--font-family--albert-sans)",
          "fontWeight": "400",
          "lineHeight": "0.51",
          "letterSpacing": "4.9px",
          "textTransform": "uppercase"
        }
      }
    },
    "spacing": {
      "blockGap": "0px",
      "padding": {
        "bottom": "0px",
        "left": "1.5rem",
        "right": "1.5rem",
        "top": "0px"
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--albert-sans)",
      "fontSize": "18px",
      "lineHeight": "1.67"
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header"
    },
    {
      "area": "footer",
      "name": "footer"
    }
  ]
}
